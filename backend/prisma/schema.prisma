generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String?          @unique
  phone           String?          @unique
  password        String?
  firebaseUid     String?          @unique
  authProvider    String           @default("LOCAL")
  firstName       String?
  lastName        String?
  role            Role             @default(USER)
  userTag         String?          @unique
  kycLevel        Int              @default(0)
  address         String?
  bvn             String?
  nin             String?
  idCardUrl       String?
  utilityBillUrl  String?
  isVerified      Boolean          @default(false)
  isActive        Boolean          @default(true)
  tenantId        String?

  avatarUrl      String?
  lastLoginAt    DateTime? @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactionPin String?
  referralCode   String? @unique
  referredById   String?
  referredBy     User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]  @relation("Referrals")

  diditSessionId String?
  diditStatus    String?

  auditLogs       AuditLog[]
  auditLogsCaused AuditLog[]       @relation("CausedBy")
  notifications   Notification[]
  sessions        Session[]
  subscriptions   Subscription[]
  transactions    Transaction[]
  virtualAccounts VirtualAccount[]
  virtualCards    VirtualCard[]
  virtualNumbers  VirtualNumber[]
  wallets         Wallet[]
}

model OtpCode {
  id         String   @id @default(uuid())
  identifier String
  code       String
  reference  String   @unique
  expiresAt  DateTime
  isUsed     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([identifier])
  @@index([reference])
}

model VirtualAccount {
  id            String   @id @default(uuid())
  userId        String
  bankName      String
  accountNumber String   @unique
  accountName   String
  currency      String   @default("NGN")
  provider      String   @default("PAYSTACK")
  providerRef   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String
  currency     String        @default("NGN")
  balance      Decimal       @default(0.00) @db.Decimal(20, 2)
  lien         Decimal       @default(0.00) @db.Decimal(20, 2)
  status       WalletStatus  @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id])

  @@unique([userId, currency])
}

model Transaction {
  id             String               @id @default(uuid())
  reference      String               @unique
  externalRef    String?              @unique
  type           TransactionType
  status         TransactionStatus    @default(PENDING)
  amount         Decimal              @db.Decimal(20, 2)
  fee            Decimal              @default(0.00) @db.Decimal(20, 2)
  total          Decimal              @db.Decimal(20, 2)
  userId         String
  walletId       String
  providerId     String?
  serviceId      String?
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  idempotencyKey String?              @unique
  virtualCardId  String?
  description    String?
  ledgerEntries  LedgerEntry[]
  provider       Provider?            @relation(fields: [providerId], references: [id])
  service        Service?             @relation(fields: [serviceId], references: [id])
  user           User                 @relation(fields: [userId], references: [id])
  virtualCard    VirtualCard?         @relation(fields: [virtualCardId], references: [id])
  wallet         Wallet               @relation(fields: [walletId], references: [id])
  attempts       TransactionAttempt[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model VirtualCard {
  id             String        @id @default(uuid())
  userId         String
  name           String
  pan            String
  fullPan        String?
  cvv            String
  expiry         String
  balance        Decimal       @default(0.00) @db.Decimal(20, 2)
  currency       String        @default("USD")
  status         String        @default("ACTIVE")
  color          String        @default("blue")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  frozen         Boolean       @default(false)
  providerCardId String?
  spendingLimit  Decimal       @default(0.00) @db.Decimal(20, 2)
  transactions   Transaction[]
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId])
}

model TransactionAttempt {
  id            String      @id @default(uuid())
  transactionId String
  attemptNumber Int
  status        String
  error         String?
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model ReconciliationLog {
  id             String   @id @default(uuid())
  status         String
  processedCount Int      @default(0)
  resolvedCount  Int      @default(0)
  failedCount    Int      @default(0)
  details        Json?
  createdAt      DateTime @default(now())
}

model LedgerEntry {
  id            String      @id @default(uuid())
  transactionId String
  accountType   AccountType
  description   String
  debit         Decimal     @default(0.00) @db.Decimal(20, 2)
  credit        Decimal     @default(0.00) @db.Decimal(20, 2)
  balanceAfter  Decimal     @db.Decimal(20, 2)
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model Provider {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  priority     Int           @default(0)
  isActive     Boolean       @default(true)
  balance      Decimal       @default(0.00) @db.Decimal(20, 2)
  config       Json
  services     Service[]
  transactions Transaction[]
}

model Service {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  type         ServiceType
  isActive     Boolean       @default(true)
  providerId   String
  basePrice    Decimal       @db.Decimal(20, 2)
  markupRules  MarkupRule[]
  provider     Provider      @relation(fields: [providerId], references: [id])
  transactions Transaction[]
}

model MarkupRule {
  id        String     @id @default(uuid())
  serviceId String
  userTier  Int?
  type      MarkupType
  value     Decimal    @db.Decimal(10, 2)
  isActive  Boolean    @default(true)
  service   Service    @relation(fields: [serviceId], references: [id])
}

model AuditLog {
  id           String   @id @default(uuid())
  action       String
  entity       String
  entityId     String
  changes      Json?
  userId       String?
  targetUserId String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  targetUser   User?    @relation(fields: [targetUserId], references: [id])
  user         User?    @relation("CausedBy", fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model VirtualNumber {
  id                  String        @id @default(uuid())
  userId              String
  vonageNumberId      String?
  phoneNumber         String        @unique
  status              String        @default("ACTIVE")
  subscriptionId      String?       @unique
  providerMonthlyCost Decimal       @default(0.00) @db.Decimal(10, 2)
  userMonthlyPrice    Decimal       @default(5000.00) @db.Decimal(10, 2)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  messages            SmsMessage[]
  subscription        Subscription? @relation(fields: [subscriptionId], references: [id])
  user                User          @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Subscription {
  id              String         @id @default(uuid())
  userId          String
  type            String
  status          String         @default("ACTIVE")
  nextBillingDate DateTime
  autoRenew       Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id])
  virtualNumber   VirtualNumber?

  @@index([userId])
  @@index([nextBillingDate])
}

model SmsMessage {
  id              String        @id @default(uuid())
  virtualNumberId String
  sender          String
  message         String
  receivedAt      DateTime      @default(now())
  virtualNumber   VirtualNumber @relation(fields: [virtualNumberId], references: [id])

  @@index([virtualNumberId])
}

model ProviderCostLog {
  id        String   @id @default(uuid())
  provider  String
  action    String
  cost      Decimal  @db.Decimal(10, 4)
  currency  String   @default("USD")
  relatedId String?
  createdAt DateTime @default(now())
}

model SoftwareProduct {
  id             String   @id @default(uuid())
  name           String
  description    String
  category       String
  brand          String
  price          Decimal  @db.Decimal(20, 2)
  originalPrice  Decimal  @db.Decimal(20, 2)
  platform       Json     // Array of strings
  licenseType    String
  image          String
  rating         Float    @default(0.0)
  sales          Int      @default(0)
  bestSeller     Boolean  @default(false)
  isActive       Boolean  @default(true)
  stock          Int      @default(-1) // -1 means unlimited API-provided, or generic
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}


enum Role {
  USER
  ADMIN
  SUPERADMIN
  SUPPORT
  API_CLIENT
}

enum WalletStatus {
  ACTIVE
  FROZEN
  RESTRICTED
}

enum TransactionType {
  FUNDING
  AIRTIME
  DATA
  ELECTRICITY
  CABLE
  EDUCATION
  TRANSFER
  WITHDRAWAL
  GIFTCARD
  GAME_TOPUP
  BETTING
  VIRTUAL_CARD_FUNDING
  EPIN
  P2P_TRANSFER
  VIRTUAL_NUMBER_RENT
  VIRTUAL_NUMBER_RENEW
  VIRTUAL_NUMBER_FUND
  VIRTUAL_CARD_CREATE
  VIRTUAL_CARD_FUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum AccountType {
  USER_WALLET
  PAYMENT_GATEWAY
  PROVIDER_WALLET
  REVENUE
  LIABILITY
  EXPENSE
}

enum ServiceType {
  AIRTIME
  DATA
  ELECTRICITY
  CABLE
  EDUCATION
  GIFTCARD
  GAME
  BETTING
}

enum MarkupType {
  FIXED
  PERCENTAGE
}
