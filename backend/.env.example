# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/db_name"

# Security (JWT - Legacy, kept for backwards compatibility)
JWT_SECRET="changeme_secret"
JWT_EXPIRES_IN="1d"
REFRESH_TOKEN_SECRET="changeme_refresh"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ==========================================
# Third-Party API Integrations
# ==========================================

# 1. Paystack (Payments) — https://dashboard.paystack.com
PAYSTACK_SECRET_KEY="sk_live_..."

# 2. ClubKonnect (Airtime & Data) — https://www.clubkonnect.com
CLUBKONNECT_BASE_URL="https://www.clubkonnect.com/API"
CLUBKONNECT_USER_ID=""
CLUBKONNECT_API_KEY=""

# 3. Reloadly (Gift Cards) — https://www.reloadly.com
RELOADLY_CLIENT_ID=""
RELOADLY_CLIENT_SECRET=""
RELOADLY_MODE="sandbox"

# 4. Didit (KYC & Identity) — https://didit.me
DIDIT_API_KEY=""
DIDIT_WORKFLOW_ID=""
DIDIT_BASE_URL="https://verification.didit.me/v3"
DIDIT_WEBHOOK_SECRET=""

# 5. HiSend OTP (Optional / Legacy)
HISEND_API_KEY=""

# 6. Mailtrap (Transactional Email) — https://mailtrap.io
MAILTRAP_API_TOKEN=""

# 7. Firebase Admin (for token verification)
# Paste the full contents of your firebase-service-account.json as a single-line JSON string
FIREBASE_SERVICE_ACCOUNT='{}'

# ==========================================
# Admin & System
# ==========================================
ADMIN_EMAIL="admin@example.com"
REDIS_URL="redis://localhost:6379"