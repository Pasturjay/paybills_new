# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/db_name"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Security (JWT)
JWT_SECRET="changeme_secret"
JWT_EXPIRES_IN="1d"
REFRESH_TOKEN_SECRET="changeme_refresh"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ==========================================
# Third-Party API Integrations
# ==========================================

# 1. Paystack (Payments)
PAYSTACK_SECRET_KEY="sk_test_..."

# 2. ClubKonnect (Airtime & Data)
CLUBKONNECT_BASE_URL="https://www.clubkonnect.com/API"
CLUBKONNECT_USER_ID="CK_..."
CLUBKONNECT_API_KEY="API_..."

# 3. Reloadly (Gift Cards)
RELOADLY_CLIENT_ID="client_id_..."
RELOADLY_CLIENT_SECRET="client_secret_..."
RELOADLY_MODE="sandbox"

# 4. Vonage / Nexmo (Virtual Numbers)
VONAGE_API_KEY="api_key_..."
VONAGE_API_SECRET="api_secret_..."

# 5. WantToPay (Virtual USD Cards)
WANTTOPAY_API_KEY="api_key_..."

# 6. Didit (KYC & Identity)
DIDIT_API_KEY="api_key_..."
DIDIT_WORKFLOW_ID="workflow_id_..."
DIDIT_BASE_URL="https://verification.didit.me/v3"
DIDIT_WEBHOOK_SECRET="secret_..."

#Admin
ADMIN_EMAIL="admin@example.com"
